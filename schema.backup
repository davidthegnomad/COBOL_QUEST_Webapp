generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  classType String // "Novice", "Data Weaver", "Procedural Sorcerer"
  level     Int      @default(1)
  xp        Int      @default(0) // Legacy
  logic     Int      @default(10) // Intelligence
  memory    Int      @default(10) // Wisdom
  createdAt DateTime @default(now())
  
  progress  UserProgress[]
  inventory UserInventory[]
}

model Quest {
  id          String   @id @default(uuid())
  slug        String   @unique // e.g., "level-1-identification"
  title       String
  description String
  division    String // "IDENTIFICATION", "ENVIRONMENT", "DATA", "PROCEDURE"
  difficulty  Int
  xpReward    Int
  statReward  String // "LOGIC" or "MEMORY"
  statAmount  Int
  
  progress    UserProgress[]
}

model UserProgress {
  id             String   @id @default(uuid())
  userId         String
  questId        String
  status         String // "LOCKED", "ACTIVE", "COMPLETED"
  codeSubmission String? // The spell cast
  completedAt    DateTime?
  
  user           User     @relation(fields: [userId], references: [id])
  quest          Quest    @relation(fields: [questId], references: [id])
}

model Item {
  id      String   @id @default(uuid())
  name    String
  effect  String
  
  inventory UserInventory[]
}

model UserInventory {
  userId  String
  itemId  String
  quantity Int
  
  user    User   @relation(fields: [userId], references: [id])
  item    Item   @relation(fields: [itemId], references: [id])

  @@id([userId, itemId])
}
